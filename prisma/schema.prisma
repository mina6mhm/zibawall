generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SalonStatus {
  PENDING_PAYMENT
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SupportStatus {
  PENDING
  IN_PROGRESS
  ANSWERED
  CLOSED
}

enum SenderRole {
  USER
  ADMIN
}

model Salon {
  id                    String      @id @default(uuid())
  name                  String
  province              String
  city                  String
  district              String?
  neighborhoods         String[]
  address               String
  lat                   Float?
  lng                   Float?
  phones                String[]
  workingHours          String
  closedDays            String[]

  rating                Float       @default(0)
  reviewsCount          Int         @default(0)

  tags                  Json        @default("[]")
  imageUrl              String
  description           String
  portfolios            String[]

  status                SalonStatus @default(PENDING_PAYMENT)
  planId                String?
  subscriptionExpiresAt DateTime?
  reminderSentAt        DateTime?

  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  socials               Social?
  reviews               Review[]
  payments              Payment[]

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([status])
  @@index([status, subscriptionExpiresAt])
}

model Social {
  id        String  @id @default(uuid())
  website   String?
  instagram String?
  whatsapp  String?
  telegram  String?
  rubika    String?
  bale      String?

  salonId   String  @unique
  salon     Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  name      String
  rating    Float
  comment   String?

  salonId   String
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model User {
  id            String   @id @default(uuid())
  name          String?
  username      String?  @unique
  phone         String?  @unique
  email         String?  @unique

  passwordHash  String?

  role          String   @default("USER")

  otpCode       String?
  otpExpiresAt  DateTime?

  salon         Salon?

  supportMessages SupportMessage[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

model Payment {
  id        String        @id @default(uuid())
  amount    Int
  status    PaymentStatus @default(PENDING)
  planId    String

  authority String?       @unique
  refId     String?

  salonId   String
  salon     Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SupportMessage {
  id          String        @id @default(uuid())
  message     String
  status      SupportStatus @default(PENDING)

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone       String?
  name        String?
  hadSalon    Boolean       @default(false)
  salonId     String?
  salonName   String?

  adminReply  String?
  repliedAt   DateTime?

  seenByUser  Boolean       @default(true)
  seenByAdmin Boolean       @default(true)

  replies     SupportReply[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([userId])
  @@index([userId, seenByUser])
  @@index([seenByAdmin])
}

model SupportReply {
  id        String     @id @default(uuid())
  message   String
  sender    SenderRole

  ticketId  String
  ticket    SupportMessage @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime   @default(now())

  @@index([ticketId])
}